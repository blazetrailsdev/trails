{
  "name": "@blazetrails/activerecord",
  "version": "0.1.0",
  "description": "ORM layer mirroring Ruby's ActiveRecord, built on @blazetrails/arel and @blazetrails/activemodel",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./connection-adapters/sqlite3-adapter.js": {
      "types": "./dist/connection-adapters/sqlite3-adapter.d.ts",
      "default": "./dist/connection-adapters/sqlite3-adapter.js"
    },
    "./connection-adapters/better-sqlite3-adapter.js": {
      "types": "./dist/connection-adapters/better-sqlite3-adapter.d.ts",
      "default": "./dist/connection-adapters/better-sqlite3-adapter.js"
    },
    "./connection-adapters/node-sqlite-adapter.js": {
      "types": "./dist/connection-adapters/node-sqlite-adapter.d.ts",
      "default": "./dist/connection-adapters/node-sqlite-adapter.js"
    },
    "./connection-adapters/expo-sqlite-adapter.js": {
      "types": "./dist/connection-adapters/expo-sqlite-adapter.d.ts",
      "default": "./dist/connection-adapters/expo-sqlite-adapter.js"
    },
    "./connection-adapters/postgresql-adapter.js": {
      "types": "./dist/connection-adapters/postgresql-adapter.d.ts",
      "default": "./dist/connection-adapters/postgresql-adapter.js"
    },
    "./connection-adapters/mysql2-adapter.js": {
      "types": "./dist/connection-adapters/mysql2-adapter.d.ts",
      "default": "./dist/connection-adapters/mysql2-adapter.js"
    },
    "./type-virtualization/*.js": {
      "types": "./dist/type-virtualization/*.d.ts",
      "default": "./dist/type-virtualization/*.js"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "default": "./dist/encryption/index.js"
    },
    "./encryption/*": {
      "types": "./dist/encryption/*.d.ts",
      "default": "./dist/encryption/*.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@blazetrails/activesupport": "workspace:*",
    "@blazetrails/arel": "workspace:*",
    "@blazetrails/activemodel": "workspace:*",
    "@blazetrails/did-you-mean": "workspace:*",
    "@blazetrails/globalid": "workspace:*"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.6.2",
    "expo-sqlite": "^15.0.0",
    "mysql2": "^3.18.2",
    "pg": "^8.19.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "expo-sqlite": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "license": "MIT"
}

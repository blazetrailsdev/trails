{
  "name": "@blazetrails/activerecord",
  "version": "0.1.0",
  "description": "ORM layer mirroring Ruby's ActiveRecord, built on @blazetrails/arel and @blazetrails/activemodel",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./connection-adapters/sqlite3-adapter.js": {
      "types": "./dist/connection-adapters/sqlite3-adapter.d.ts",
      "default": "./dist/connection-adapters/sqlite3-adapter.js"
    },
    "./adapters/postgresql-adapter.js": {
      "types": "./dist/adapters/postgresql-adapter.d.ts",
      "default": "./dist/adapters/postgresql-adapter.js"
    },
    "./adapters/mysql2-adapter.js": {
      "types": "./dist/adapters/mysql2-adapter.d.ts",
      "default": "./dist/adapters/mysql2-adapter.js"
    },
    "./tsc": {
      "types": "./dist/tsc-wrapper/index.d.ts",
      "default": "./dist/tsc-wrapper/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "bin": {
    "trails-tsc": "./dist/tsc-wrapper/cli.js"
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@blazetrails/activesupport": "workspace:*",
    "@blazetrails/arel": "workspace:*",
    "@blazetrails/activemodel": "workspace:*"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}

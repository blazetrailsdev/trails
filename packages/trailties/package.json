{
  "name": "@blazetrails/trailties",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "trails": "./bin/trails.js"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./generators": "./dist/generators/index.js",
    "./vite": {
      "types": "./dist/server/vite-plugin.d.ts",
      "default": "./dist/server/vite-plugin.js"
    },
    "./template-builder": {
      "types": "./dist/template-builder/index.d.ts",
      "default": "./dist/template-builder/index.js"
    },
    "./template-builder/testing": {
      "types": "./dist/template-builder/testing.d.ts",
      "default": "./dist/template-builder/testing.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "dependencies": {
    "@blazetrails/activerecord": "workspace:*",
    "@blazetrails/activesupport": "workspace:*",
    "@blazetrails/rack": "workspace:*",
    "@blazetrails/actionpack": "workspace:*",
    "commander": "^14.0.0",
    "vite": "^7.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}

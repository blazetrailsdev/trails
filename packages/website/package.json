{
  "name": "@blazetrails/website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm run build:sw",
    "dev": "vite dev --host",
    "build:sw": "vite build --config vite.sw.config.ts",
    "build": "pnpm run build:sw && vite build && pnpm run docs:build",
    "preview": "vite preview",
    "test": "vitest run",
    "docs:typedoc": "tsc --build ../../tsconfig.json && typedoc --tsconfig ../../tsconfig.json && node scripts/escape-typedoc.mjs",
    "docs:dev": "pnpm run docs:typedoc && vitepress dev docs",
    "docs:build": "pnpm run docs:typedoc && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "dompurify": "^3.3.3",
    "jsdom": "^29.0.1",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "sql.js": "^1.14.1",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "vite": "^6.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}

{
  "name": "@blazetrails/actionview",
  "version": "0.1.0",
  "description": "ActionView — mirroring Rails ActionView",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./strict-locals": {
      "types": "./dist/strict-locals.d.ts",
      "default": "./dist/strict-locals.js"
    },
    "./tse-modules": {
      "types": "./types/tse-modules.d.ts",
      "default": "./types/tse-modules.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "files": [
    "dist",
    "types"
  ],
  "license": "MIT",
  "dependencies": {
    "@blazetrails/activesupport": "workspace:*",
    "@blazetrails/did-you-mean": "workspace:*",
    "@blazetrails/tse-compiler": "workspace:*"
  }
}

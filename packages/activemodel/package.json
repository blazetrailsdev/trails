{
  "name": "@blazetrails/activemodel",
  "version": "0.1.0",
  "description": "Attributes, validations, callbacks, and serialization, mirroring Ruby's ActiveModel",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./yaml": {
      "types": "./dist/attribute-set/codecs/yaml.d.ts",
      "default": "./dist/attribute-set/codecs/yaml.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "@blazetrails/activesupport": "workspace:*",
    "bcryptjs": "^3.0.3"
  }
}
